		"@sveltejs/kit": "^2.20.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@tailwindcss/vite": "^4.1.0",
		"svelte": "^5.25.0",
		"svelte-check": "^4.1.0",
		"tailwindcss": "^4.1.0",
		"typescript": "^5.8.0",
		"vite": "^6.2.0"
	}
}
