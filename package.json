{
	"name": "ai-forum-website-v3",
	"version": "1.0.0",
	"private": true,
	"description": "AI Forum Bangladesh website. Fully static SvelteKit + Tailwind build.",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && node scripts/postbuild.mjs",
